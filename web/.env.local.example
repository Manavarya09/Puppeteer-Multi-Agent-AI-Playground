# Choose ONE provider as primary; the other is optional.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional fast-path for planner / critic
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Default models (override per-agent in lib/llm.ts)
DEFAULT_MODEL=openai/gpt-4o-mini
FAST_MODEL=groq/llama-3.3-70b-versatile

# Optional: where the public site is served from
NEXT_PUBLIC_SITE_URL=http://localhost:3000
